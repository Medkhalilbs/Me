# ─── Database (Turso) ────────────────────────────────────────────────────────
TURSO_URL=
TURSO_TOKEN=

# ─── Cloudinary (image & CV uploads) ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=              # generate with: openssl rand -hex 32
ADMIN_INITIAL_PASSWORD=  # set your admin password, or one will be generated on first boot

# ─── Optional Customization ───────────────────────────────────────────────────
ALLOWED_ORIGIN=          # your production domain, e.g. https://myportfolio.com
ADMIN_PATH=              # admin URL path, defaults to 'admin'
DEFAULT_NAME=            # your full name
DEFAULT_TITLE=           # your job title
DEFAULT_EMAIL=           # your email
DEFAULT_LOCATION=        # your city, country
DEFAULT_LINKEDIN=        # your LinkedIn URL
DEFAULT_GITHUB=          # your GitHub URL
DEFAULT_HEADING=         # hero section main heading
DEFAULT_SUBTITLE=        # hero section subtitle
DEFAULT_CALLOUT_TITLE=   # about section callout title
DEFAULT_CALLOUT_TEXT=    # about section callout text

# ─── Render sets this automatically — do NOT set it manually ─────────────────
# NODE_ENV=
# PORT=