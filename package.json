{
  "name": "mkbs-portfolio",
  "version": "1.0.0",
  "description": "Mohamed Khalil Ben Sedrine — Full Stack Portfolio with Admin Panel",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "tsx watch server/index.ts",
    "dev:all": "concurrently -k -p \"[{name}]\" -n \"VITE,SERVER\" -c \"cyan,magenta\" \"npm run dev\" \"npm run server\"",
    "build": "vue-tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "pinia": "^2.2.0",
    "axios": "^1.7.0",
    "@lucide/vue": "^1.21.0",
    "@vueuse/core": "^11.0.0",
    "express": "^4.19.0",
    "sql.js": "^1.12.0",
    "multer": "^2.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.0",
    "vite": "^5.4.0",
    "typescript": "^5.5.0",
    "vue-tsc": "^2.1.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "tsx": "^4.19.0",
    "concurrently": "^9.0.0",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.0",
    "@types/bcryptjs": "^2.4.0",
    "@types/cors": "^2.8.0",
    "@types/node": "^22.0.0",
    "@types/sql.js": "^1.4.0"
  }
}
